{
    "name": "setono/sylius-wishlist-plugin",
    "description": "Setono example plugin for Sylius.",
    "license": "MIT",
    "type": "sylius-plugin",
    "keywords": [
        "sylius",
        "sylius-plugin"
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/collections": "^2.0",
        "doctrine/persistence": "^3.0 || ^4.0",
        "setono/client-bundle": "^1.2",
        "setono/composite-compiler-pass": "^1.3",
        "setono/doctrine-orm-trait": "^1.4",
        "sylius/core": "^2.2",
        "sylius/core-bundle": "^2.2",
        "sylius/order": "^2.2",
        "sylius/product-bundle": "^2.2",
        "sylius/resource-bundle": "^1.12",
        "sylius/user": "^2.2",
        "symfony/config": "^6.4 || ^7.4",
        "symfony/dependency-injection": "^6.4 || ^7.4",
        "symfony/event-dispatcher": "^6.4 || ^7.4",
        "symfony/form": "^6.4 || ^7.4",
        "symfony/http-foundation": "^6.4 || ^7.4",
        "symfony/http-kernel": "^6.4 || ^7.4",
        "symfony/options-resolver": "^6.4 || ^7.4",
        "symfony/routing": "^6.4 || ^7.4",
        "symfony/security-bundle": "^6.4 || ^7.4",
        "symfony/security-core": "^6.4 || ^7.4",
        "symfony/security-http": "^6.4 || ^7.4",
        "symfony/translation-contracts": "^3.0",
        "symfony/uid": "^6.4 || ^7.4",
        "twig/twig": "^3.8",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "api-platform/symfony": "~4.2.1",
        "setono/sylius-plugin": "^2.0",
        "sylius/grid-bundle": "^1.15",
        "sylius/sylius": "~2.2.5",
        "symfony/debug-bundle": "^6.4 || ^7.4",
        "symfony/dotenv": "^6.4 || ^7.4",
        "symfony/intl": "^6.4 || ^7.4",
        "symfony/property-info": "^6.4 || ^7.4",
        "symfony/serializer": "^6.4 || ^7.4",
        "symfony/web-profiler-bundle": "^6.4 || ^7.4",
        "symfony/webpack-encore-bundle": "^2.2"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Setono\\SyliusWishlistPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Setono\\SyliusWishlistPlugin\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Application/Kernel.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "php-http/discovery": false,
            "phpstan/extension-installer": true,
            "symfony/thanks": false
        },
        "policy": {
            "advisories": {
                "block": false
            }
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "check-style": "ecs check",
        "fix-style": "ecs check --fix",
        "phpunit": "phpunit"
    }
}
